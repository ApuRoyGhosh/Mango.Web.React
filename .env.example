# Direct Microservice URLs (Bypassing API Gateway)
# Call each service directly on its own port

VITE_AUTH_API_BASE=http://localhost:7002/api/auth
VITE_PRODUCT_API_BASE=http://localhost:7000/api/product
VITE_COUPON_API_BASE=http://localhost:7001/api/coupon
VITE_CART_API_BASE=http://localhost:7003/api/cart
VITE_ORDER_API_BASE=http://localhost:7004/api/order

# For production, update to your deployment URLs:
# VITE_AUTH_API_BASE=https://yourdomain.com/api/auth
# VITE_PRODUCT_API_BASE=https://yourdomain.com/api/product
# etc.

# Optional: Stripe Key (when payment integration is added)
# VITE_STRIPE_PUBLIC_KEY=pk_test_your_key_here

